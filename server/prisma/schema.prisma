generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  expiresAt DateTime

  @@index([userId])
}

enum ArtworkCategory {
  PAINTING
  WATERCOLOR
  WALL_PAINTING
}


model Artwork {
  id          String  @id @default(uuid())
  title       String
  slug        String  @unique // SEO и красивые URL
  description String?
  year        Int?
  widthCm     Int?
  heightCm    Int?
  materials   String?
  priceCents  Int? //  корректное хранение денег
  currency    String? @default("EUR") //  мультивалютность

  category    ArtworkCategory?

  isPublished Boolean   @default(false) // черновики и управление видимостью
  publishedAt DateTime? // сортировка и история публикации

  // обложка
  coverImageId String?  @unique // одна картинка = максимум одна обложка
  coverImage   Image?   @relation("ArtworkCover", fields: [coverImageId], references: [id], onDelete: SetNull)

  // галерея
  images     Image[]     @relation("ArtworkImages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Image { 
  id          String  @id @default(uuid())

  // для S3/R2/MinIO
  key       String   @unique   // например: "artworks/<artworkId>/<uuid>.jpg"
  url       String  
  mimeType  String?
  sizeBytes Int?
  widthPx   Int?
  heightPx  Int?

  // связь с Artwork (много изображений на одну картину)
  artworkId String?
  artwork   Artwork? @relation("ArtworkImages", fields: [artworkId], references: [id], onDelete: Cascade)

  // обратная связь для cover relation
  usedAsCoverFor Artwork? @relation("ArtworkCover")


  createdAt DateTime @default(now())

  @@index([artworkId])
}
